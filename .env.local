# ============================================
# APPLICATION CONFIG
# ============================================
NODE_ENV="development"
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"
NEXT_PUBLIC_WIDGET_URL="http://localhost:3000/widget"
NEXT_PUBLIC_APP_NAME="SalesBrain"

# ============================================
# LOGGING & DEBUG
# ============================================
DEBUG="salesbrain:*"
LOG_LEVEL="debug"

# ============================================
# AI CONFIGURATION
# ============================================
# Maximum tokens per API call
MAX_TOKENS="4096"
# Temperature for AI responses (0-1, lower=more consistent)
AI_TEMPERATURE="0.7"
# Whether to show AI assistant label in widget
NEXT_PUBLIC_AI_TRANSPARENCY="true"
